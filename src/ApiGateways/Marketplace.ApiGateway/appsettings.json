{
  "ReverseProxy": {
    "Routes": {
      "catalog-brands-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/brands"
        }
      },
      "catalog-brands": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/brands/{**catch-all}"
        }
      },
      "catalog-categories-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/categories"
        }
      },
      "catalog-categories": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "catalog-products-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/products"
        }
      },
      "catalog-products": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "inventory-items-root": {
        "ClusterId": "inventory",
        "Match": {
          "Path": "/api/inventory-items"
        }
      },
      "inventory-items": {
        "ClusterId": "inventory",
        "Match": {
          "Path": "/api/inventory-items/{**catch-all}"
        }
      },
      "order-checkout-root": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/checkout"
        }
      },
      "order-checkout": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/checkout/{**catch-all}"
        }
      },
      "order-orders-root": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders"
        }
      },
      "order-orders": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "payment-payments-root": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/api/payments"
        }
      },
      "payment-payments": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      },
      "payment-fake-3ds-root": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/fake-3ds/payments"
        }
      },
      "payment-fake-3ds": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/fake-3ds/payments/{**catch-all}"
        }
      },
      "notification-notifications-root": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notifications"
        }
      },
      "notification-notifications": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "notification-preferences-root": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notification-preferences"
        }
      },
      "notification-preferences": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notification-preferences/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": {
          "catalog": {
            "Address": "http://localhost:8080/"
          }
        }
      },
      "inventory": {
        "Destinations": {
          "inventory": {
            "Address": "http://localhost:8081/"
          }
        }
      },
      "notification": {
        "Destinations": {
          "notification": {
            "Address": "http://localhost:8082/"
          }
        }
      },
      "payment": {
        "Destinations": {
          "payment": {
            "Address": "http://localhost:8083/"
          }
        }
      },
      "order": {
        "Destinations": {
          "order": {
            "Address": "http://localhost:8084/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*"
}
