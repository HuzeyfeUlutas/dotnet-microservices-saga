{
  "Gateway": {
    "Cors": {
      "AllowedOrigins": []
    },
    "RateLimiting": {
      "PermitLimit": 100,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "Authentication": {
      "Enabled": true,
      "Authority": "",
      "Audience": "marketplace-api",
      "ValidIssuer": "",
      "RequireHttpsMetadata": true,
      "ClockSkewMinutes": 2
    }
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-brands-get-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/brands",
          "Methods": [
            "GET"
          ]
        }
      },
      "catalog-brands-get": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/brands/{**catch-all}",
          "Methods": [
            "GET"
          ]
        }
      },
      "catalog-categories-get-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/categories",
          "Methods": [
            "GET"
          ]
        }
      },
      "catalog-categories-get": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/categories/{**catch-all}",
          "Methods": [
            "GET"
          ]
        }
      },
      "catalog-products-get-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/products",
          "Methods": [
            "GET"
          ]
        }
      },
      "catalog-products-get": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/products/{**catch-all}",
          "Methods": [
            "GET"
          ]
        }
      },
      "catalog-brands-manage-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/brands",
          "Methods": [
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ]
        },
        "AuthorizationPolicy": "catalog-management"
      },
      "catalog-brands-manage": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/brands/{**catch-all}",
          "Methods": [
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ]
        },
        "AuthorizationPolicy": "catalog-management"
      },
      "catalog-categories-manage-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/categories",
          "Methods": [
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ]
        },
        "AuthorizationPolicy": "catalog-management"
      },
      "catalog-categories-manage": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/categories/{**catch-all}",
          "Methods": [
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ]
        },
        "AuthorizationPolicy": "catalog-management"
      },
      "catalog-products-manage-root": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/products",
          "Methods": [
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ]
        },
        "AuthorizationPolicy": "catalog-management"
      },
      "catalog-products-manage": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/products/{**catch-all}",
          "Methods": [
            "POST",
            "PUT",
            "DELETE",
            "PATCH"
          ]
        },
        "AuthorizationPolicy": "catalog-management"
      },
      "inventory-items-root": {
        "ClusterId": "inventory",
        "Match": {
          "Path": "/api/inventory-items"
        },
        "AuthorizationPolicy": "inventory-management"
      },
      "inventory-items": {
        "ClusterId": "inventory",
        "Match": {
          "Path": "/api/inventory-items/{**catch-all}"
        },
        "AuthorizationPolicy": "inventory-management"
      },
      "order-checkout-pay": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/checkout/pay",
          "Methods": [
            "POST"
          ]
        },
        "AuthorizationPolicy": "checkout"
      },
      "order-orders-root": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders"
        },
        "AuthorizationPolicy": "customer-or-admin"
      },
      "order-orders": {
        "ClusterId": "order",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "AuthorizationPolicy": "customer-or-admin"
      },
      "payment-status": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/api/payments/{id:guid}",
          "Methods": [
            "GET"
          ]
        },
        "AuthorizationPolicy": "customer-or-admin"
      },
      "payment-fake-3ds-root": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/fake-3ds/payments"
        }
      },
      "payment-fake-3ds": {
        "ClusterId": "payment",
        "Match": {
          "Path": "/fake-3ds/payments/{**catch-all}"
        }
      },
      "notification-preferences-root": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notification-preferences"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "notification-preferences": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notification-preferences/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "notification-notifications-root": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notifications"
        },
        "AuthorizationPolicy": "support"
      },
      "notification-notifications": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "AuthorizationPolicy": "support"
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": {
          "catalog": {
            "Address": "http://localhost:8080/"
          }
        }
      },
      "inventory": {
        "Destinations": {
          "inventory": {
            "Address": "http://localhost:8081/"
          }
        }
      },
      "notification": {
        "Destinations": {
          "notification": {
            "Address": "http://localhost:8082/"
          }
        }
      },
      "payment": {
        "Destinations": {
          "payment": {
            "Address": "http://localhost:8083/"
          }
        }
      },
      "order": {
        "Destinations": {
          "order": {
            "Address": "http://localhost:8084/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*"
}
