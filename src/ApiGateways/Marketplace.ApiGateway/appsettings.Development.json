{
  "Gateway": {
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:4200",
        "http://localhost:5173"
      ]
    },
    "RateLimiting": {
      "PermitLimit": 1000,
      "QueueLimit": 0,
      "WindowSeconds": 60
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "catalog": {
        "Destinations": {
          "catalog": {
            "Address": "http://localhost:8080/"
          }
        }
      },
      "inventory": {
        "Destinations": {
          "inventory": {
            "Address": "http://localhost:8081/"
          }
        }
      },
      "notification": {
        "Destinations": {
          "notification": {
            "Address": "http://localhost:8082/"
          }
        }
      },
      "payment": {
        "Destinations": {
          "payment": {
            "Address": "http://localhost:8083/"
          }
        }
      },
      "order": {
        "Destinations": {
          "order": {
            "Address": "http://localhost:8084/"
          }
        }
      }
    }
  }
}
