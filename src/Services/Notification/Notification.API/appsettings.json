{
  "ConnectionStrings": {
    "NotificationDatabase": "Host=localhost;Port=5434;Database=notificationdb;Username=postgres;Password=postgres"
  },
  "ElasticSearch": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "notification-logs-{0:yyyy.MM}"
  },
  "OpenTelemetry": {
    "ServiceName": "Notification",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "NotificationDelivery": {
    "DispatcherIntervalSeconds": 10,
    "BatchSize": 20
  },
  "EmailDelivery": {
    "ProviderName": "Logging",
    "SimulatedLatencyMs": 0,
    "FailureRecipients": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
