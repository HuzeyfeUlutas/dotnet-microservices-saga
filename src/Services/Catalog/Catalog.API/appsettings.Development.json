{
  "ElasticSearch": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "catalog-logs-dev-{0:yyyy.MM}"
  },
  "OpenTelemetry": {
    "ServiceName": "Catalog",
    "ServiceVersion": "1.0.0-dev",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
