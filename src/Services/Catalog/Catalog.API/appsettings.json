{
  "ConnectionStrings": {
    "CatalogDatabase": "Host=localhost;Port=5432;Database=catalogdb;Username=postgres;Password=postgres"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "ElasticSearch": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "catalog-logs-{0:yyyy.MM}"
  },
  "OpenTelemetry": {
    "ServiceName": "Catalog",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
